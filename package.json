{
  "name": "attendance-system-web-app",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "npx next dev",
    "postinstall": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 npx prisma generate --no-hints",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 npx next build",
    "start": "npx next start",
    "lint": "npx eslint .",
    "test:unit": "vitest run",
    "loadtest:attendance:burst": "k6 run load-tests/attendance-burst.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma db push --skip-generate",
    "db:seed": "node prisma/seed.cjs",
    "db:setup": "npx prisma db push --skip-generate --accept-data-loss --schema prisma/schema.prisma && node prisma/seed.cjs",
    "db:studio": "npx prisma studio",
    "vercel:link": "npx vercel link",
    "vercel:env:pull": "npx vercel env pull .env.vercel.local",
    "deploy:preview": "npx vercel",
    "deploy:prod": "npx vercel --prod"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@prisma/client": "^6.19.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.574.0",
    "motion": "^12.38.0",
    "next": "^16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdfjs-dist": "^5.5.207",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
