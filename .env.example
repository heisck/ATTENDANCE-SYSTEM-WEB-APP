# Database Configuration
# Required: PostgreSQL connection string.
# In production on Vercel, use a pooled connection URL here.
DATABASE_URL="postgresql://user:password@localhost:5432/attendance_db"

# Optional: Direct database URL for Prisma migrations/admin work.
# In production, keep this as the non-pooled/direct URL when your provider supports it.
DIRECT_URL="postgresql://user:password@localhost:5432/attendance_db"

# Redis / Shared Cache
# Required in production for attendance rate limiting and burst-load cache sharing
# REDIS_URL="redis://default:password@host:6379"
# KV_URL="redis://default:password@host:6379"
# UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Authentication
# Required: NextAuth secret for JWT signing and session encryption
# Generate with: openssl rand -hex 32
AUTH_SECRET="your-secure-random-secret-here"

# NextAuth (alternative to AUTH_SECRET for compatibility)
# NEXTAUTH_SECRET="your-secure-random-secret-here"

# WebAuthn/Passkey Configuration
# Required in production: FQDN/domain where the application is hosted
# WEBAUTHN_RP_ID="example.com"

# Required in production: Full origin URL (protocol + domain + port)
# WEBAUTHN_ORIGIN="https://example.com"

# Optional: Relying Party name shown to users during passkey registration
# WEBAUTHN_RP_NAME="AttendanceIQ"

# Cron Jobs & Background Tasks
# Required: Secret token to authenticate reminder/cron job requests
# This prevents unauthorized access to scheduled tasks
REMINDER_CRON_SECRET="your-cron-secret-here"

# Initial organization bootstrap
# Optional but strongly recommended in production if you need a one-time
# unauthenticated bootstrap before a super-admin exists.
# ORGANIZATION_ONBOARDING_SECRET="your-bootstrap-secret-here"

# Environment
# Set to "production" for production deployments
NODE_ENV="development"

# Application Server
# Port the Next.js dev server runs on (development only)
PORT="3000"

# Note on IP-based Access Control
# This application supports checking if students are on campus via IP ranges.
# Configure trusted IP ranges in the admin dashboard, not via environment variables.
# The application expects to be behind a trusted reverse proxy that sets:
# - X-Forwarded-For header: Client's original IP
# - X-Real-IP header: Alternative IP header (fallback)
# 
# Trusted reverse proxies include:
# - Vercel (automatically sets X-Forwarded-For)
# - Render.com (automatically sets X-Forwarded-For)
# - Netlify (sets proxy headers)
# - Custom NGINX/Apache proxies (if configured correctly)
#
# IMPORTANT: Only trust these headers if your application is behind a trusted proxy!
# Misconfiguration allows attackers to spoof their location.

# Email Configuration (Gmail SMTP, used for verification/reset/invites)
# Required in production if you want outbound emails:
# 1) Use a Gmail account with 2FA enabled
# 2) Create an App Password in Google Account security settings
# 3) Put the 16-character app password below (no spaces)
GMAIL_SMTP_USER="yourgmail@gmail.com"
GMAIL_SMTP_APP_PASSWORD="your-16-char-app-password"

# Optional overrides
# GMAIL_FROM_EMAIL="AttendanceIQ <yourgmail@gmail.com>"
# GMAIL_SMTP_HOST="smtp.gmail.com"
# GMAIL_SMTP_PORT="465"

# Cloudinary Asset Storage
# Required in production if you want enrollment/profile images and file uploads to persist.
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-cloudinary-api-key"
# CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
# CLOUDINARY_UPLOAD_FOLDER="attendanceiq"

# Amazon Rekognition Face Enrollment / Verification
# Required for face liveness and face match flows.
# AWS_REGION="eu-north-1"
# AWS_REKOGNITION_REGION="eu-west-1"
# AWS_ACCESS_KEY_ID="your-aws-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# AWS_COGNITO_IDENTITY_POOL_ID="eu-north-1:example-pool-id"
# AWS_COGNITO_REGION="eu-north-1"

# Optional tuning
# FACE_FLOW_TOKEN_TTL_MINUTES="30"
# PENDING_FACE_VERIFICATION_TTL_SECONDS="300"
# FACE_LIVENESS_MIN_CONFIDENCE="70"
# FACE_MATCH_MIN_SIMILARITY="90"

# Web Push Notifications
# Required: VAPID public key for push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY="your-public-vapid-key"

# Required: VAPID private key for sending push notifications
WEB_PUSH_PRIVATE_KEY="your-private-vapid-key"
